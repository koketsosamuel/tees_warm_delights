---
import { nav, waBase, telLink } from '../data/site.js';
const { active = '' } = Astro.props;
const isActive = (href) => href === '/' ? active === '/' : active.startsWith(href);
---
<nav class="top">
  <div class="wrap">
    <a href="/" class="brand" aria-label="CG Cakes — home">
      <div class="mark"><img src="/img/logo.jpg" alt="" width="44" height="44"></div>
      <div class="wm"><div class="s">CG</div><div class="d">CAKES</div></div>
    </a>
    <div class="links">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'is-active' : ''} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </div>
    <div class="cta-pair">
      <a href="/contact" class="btn btn-ghost hide-mobile">Order a cake</a>
    </div>
  </div>
</nav>

<button class="burger" id="burger" aria-label="Menu" aria-expanded="false"><span></span></button>
<div class="menu-scrim" id="menuScrim"></div>
<div class="mobile-menu" id="mobileMenu" role="menu">
  {nav.map((item) => (
    <a href={item.href} class={isActive(item.href) ? 'is-active' : ''}>{item.label}</a>
  ))}
  <div class="sep"></div>
  <div class="ctas">
    <a class="btn btn-primary" href={waBase} target="_blank" rel="noopener">WhatsApp</a>
    <a class="btn btn-ghost" href={telLink}>Call</a>
  </div>
</div>
