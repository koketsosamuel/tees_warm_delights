<script is:inline>
  // Tweak defaults
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "accent": "berry-gold",
    "displayFont": "Playfair Display",
    "background": "paper"
  }/*EDITMODE-END*/;

  // Mobile menu
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobileMenu');
  if (burger) {
    burger.addEventListener('click', () => {
      const on = !mobileMenu.classList.contains('on');
      burger.classList.toggle('on', on);
      mobileMenu.classList.toggle('on', on);
      document.getElementById('menuScrim').classList.toggle('on', on);
    });
    const close = () => {
      burger.classList.remove('on');
      mobileMenu.classList.remove('on');
      document.getElementById('menuScrim').classList.remove('on');
    };
    mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
    document.getElementById('menuScrim').addEventListener('click', close);
  }

  // Menu filtering
  const cats = document.querySelectorAll('.cat');
  const cards = document.querySelectorAll('#menuGrid .card');
  cats.forEach(b => b.addEventListener('click', () => {
    cats.forEach(x => x.classList.remove('on'));
    b.classList.add('on');
    const v = b.dataset.cat;
    cards.forEach(c => {
      c.style.display = (v === 'all' || c.dataset.cat === v) ? '' : 'none';
    });
  }));

  // Order CTAs on each card -> prefilled WhatsApp
  cards.forEach(c => {
    c.addEventListener('click', (e) => {
      const name = c.querySelector('.name').textContent.trim();
      const msg = encodeURIComponent(`Hi Tee, I'd like to order: ${name}`);
      window.open(`https://wa.me/27678106965?text=${msg}`, '_blank');
    });
  });

  // Form submit -> WhatsApp
  function submitForm(e) {
    e.preventDefault();
    const f = e.target;
    const d = Object.fromEntries(new FormData(f));
    const text = `Hi Tee! I'd like to place an order.%0A%0A` +
      `*Name:* ${d.name}%0A` +
      `*Phone:* ${d.phone}%0A` +
      (d.email ? `*Email:* ${d.email}%0A` : '') +
      `*Item:* ${d.item}%0A` +
      `*Needed by:* ${d.date}%0A` +
      (d.notes ? `*Notes:* ${d.notes}%0A` : '');
    const t = document.getElementById('toast');
    t.classList.add('on');
    setTimeout(() => t.classList.remove('on'), 3500);
    setTimeout(() => window.open(`https://wa.me/27678106965?text=${text}`, '_blank'), 400);
    f.reset();
  }

  // Min date = tomorrow (we need 24h)
  const dateInput = document.querySelector('input[name=date]');
  if (dateInput) {
    const t = new Date(); t.setDate(t.getDate()+1);
    dateInput.min = t.toISOString().slice(0,10);
  }

  // --- Tweaks protocol ---
  const palettes = {
    'navy-olive': {navy:'#1a1f4d','navy-ink':'#141837',olive:'#9a9646','olive-deep':'#7a7835',blush:'#fce8e8',cream:'#faf3e8','cream-warm':'#f3ead8'},
    'choc-cream': {navy:'#3a2618','navy-ink':'#2a1a10',olive:'#c6935b','olive-deep':'#9e7040',blush:'#f5e6d3',cream:'#f8f0e1','cream-warm':'#efe0c4'},
    'berry-gold': {navy:'#6b1d2f','navy-ink':'#4e1322',olive:'#c49b3c','olive-deep':'#9e7b26',blush:'#f8e5e2',cream:'#faf0e0','cream-warm':'#f0e0c0'},
    'forest-butter': {navy:'#2e4a35',"navy-ink":'#1f3626',olive:'#d4a64a','olive-deep':'#a88534',blush:'#ece9d8',cream:'#f5efde',"cream-warm":'#ede1c0'},
  };
  const bgs = {paper:'#fdfaf4', blush:'#fce8e8', cream:'#f3ead8'};

  function applyTweaks(t){
    const p = palettes[t.accent] || palettes['navy-olive'];
    const root = document.documentElement;
    Object.entries(p).forEach(([k,v])=>root.style.setProperty('--'+k, v));
    root.style.setProperty('--paper', bgs[t.background] || bgs.paper);
    // Update display font
    document.querySelectorAll('.serif, h1, h2, h3, h4, .name, .form-title, .faq-item summary, .story .sig').forEach(el=>{});
    const style = document.getElementById('tw-font-style') || (()=>{
      const s=document.createElement('style');s.id='tw-font-style';document.head.appendChild(s);return s;
    })();
    style.textContent = `h1, h2, h3, h4, .name, .form-title, .faq-item summary, .feature h3, .sec-head h2, .quote .t, .footer .lead { font-family: '${t.displayFont}', 'DM Serif Display', serif !important; }
    @import url('https://fonts.googleapis.com/css2?family=${t.displayFont.replace(/ /g,'+')}:ital,wght@0,400;0,600;1,400&display=swap');`;
    // highlight swatches
    document.querySelectorAll('#tweaks [data-acc]').forEach(b=>b.classList.toggle('on', b.dataset.acc===t.accent));
    document.querySelectorAll('#tweaks [data-bg]').forEach(b=>b.classList.toggle('on', b.dataset.bg===t.background));
    const sel = document.getElementById('tw-font'); if(sel) sel.value = t.displayFont;
  }
  let currentTweaks = {...TWEAK_DEFAULTS};
  applyTweaks(currentTweaks);

  function setTweak(k,v){
    currentTweaks = {...currentTweaks, [k]:v};
    applyTweaks(currentTweaks);
    try{ window.parent.postMessage({type:'__edit_mode_set_keys',edits:{[k]:v}},'*'); }catch(e){}
  }
  document.querySelectorAll('#tweaks [data-acc]').forEach(b=>b.onclick=()=>setTweak('accent',b.dataset.acc));
  document.querySelectorAll('#tweaks [data-bg]').forEach(b=>b.onclick=()=>setTweak('background',b.dataset.bg));
  document.getElementById('tw-font').onchange=(e)=>setTweak('displayFont',e.target.value);

  // Listener BEFORE announcing availability
  window.addEventListener('message', (e) => {
    const m = e.data;
    if (!m || !m.type) return;
    if (m.type === '__activate_edit_mode')   document.getElementById('tweaks').classList.add('on');
    if (m.type === '__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('on');
  });
  try{ window.parent.postMessage({type:'__edit_mode_available'},'*'); }catch(e){}
</script>
