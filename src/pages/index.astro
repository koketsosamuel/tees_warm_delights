---
import Layout from '../layouts/Layout.astro';
import CakeCard from '../components/CakeCard.astro';
import Icon from '../components/Icon.astro';
import { site, cakes, testimonials, waBase, waLink, telLink } from '../data/site.js';

const featured = cakes.filter(c => c.cat === 'celebration').slice(0, 3);
const orderWa = waLink("Hi CG Cakes, I'd like to order a cake. Could you tell me about sizes and options?");
---
<Layout active="/">

<!-- HERO -->
<header class="hero">
  <div class="wrap grid">
    <div>
      <span class="tag"><span class="dot"></span> Custom cake studio · Made to order</span>
      <h1>Cakes worth<br><em>the occasion.</em></h1>
      <p class="lede">Custom celebration cakes, graduation and bento cakes, and decorated cupcakes — hand-piped in buttercream and finished the day you collect. Tell us the moment; we'll make the cake.</p>
      <div class="ctas">
        <a class="btn btn-primary btn-lg" href={waBase} target="_blank" rel="noopener">
          <Icon name="whatsapp" class="wa-ico" /> Design your cake
        </a>
        <a class="btn btn-ghost btn-lg" href="/menu">See our cakes</a>
      </div>
      <div class="meta">
        <div class="mi"><span class="k">Based in</span><span class="v">{site.location}</span></div>
        <div class="mi"><span class="k">Lead time</span><span class="v">{site.leadTime}</span></div>
        <div class="mi"><span class="k">Delivery</span><span class="v">Local & collection</span></div>
      </div>
    </div>

    <div class="stack">
      <div class="b"><img src="/img/cake-milestone-gold.jpg" alt="Gold milestone birthday cake" width="520" height="600"></div>
      <div class="a"><img src="/img/cake-floral-pink.jpg" alt="Floral buttercream celebration cake" width="620" height="820"></div>
      <div class="c"><img src="/img/cupcakes-strawberry.jpg" alt="Box of strawberry cupcakes" width="460" height="460"></div>
      <div class="stamp" aria-hidden="true">
        <svg viewBox="0 0 200 200">
          <defs>
            <path id="arc" d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0"></path>
          </defs>
          <text fill="#faf3e8" font-family="Inter" font-size="14" letter-spacing="4" font-weight="600">
            <textPath href="#arc">· BAKED TO ORDER · SINCE {site.since} · BAKED TO ORDER · </textPath>
          </text>
        </svg>
        <div class="ctr"><span>cake</span></div>
      </div>
    </div>
  </div>
</header>

<!-- Ticker -->
<div class="ticker">
  <div class="ticker-track">
    <span>Birthday cakes <span class="dot">✦</span> Graduation cakes <span class="dot">✦</span> Cupcakes <span class="dot">✦</span> Bento cakes <span class="dot">✦</span> Number cakes <span class="dot">✦</span> Christening cakes <span class="dot">✦</span> Custom designs <span class="dot">✦</span></span>
    <span>Birthday cakes <span class="dot">✦</span> Graduation cakes <span class="dot">✦</span> Cupcakes <span class="dot">✦</span> Bento cakes <span class="dot">✦</span> Number cakes <span class="dot">✦</span> Christening cakes <span class="dot">✦</span> Custom designs <span class="dot">✦</span></span>
  </div>
</div>

<!-- SIGNATURE PREVIEW -->
<section class="menu">
  <div class="wrap">
    <div class="sec-head">
      <div class="lt">
        <span class="eyebrow">Our signatures</span>
        <h2>The cakes people <em>come back for.</em></h2>
        <p>A few of our most-loved designs. Every one can be sized for your guest count and dressed for the occasion.</p>
      </div>
      <a href="/menu" class="btn btn-olive">View all cakes</a>
    </div>
    <div class="grid-menu">
      {featured.map((cake) => <CakeCard cake={cake} />)}
    </div>
  </div>
</section>

<!-- FEATURED custom -->
<section class="feature">
  <div class="wrap">
    <div class="grid">
      <div class="imgwrap"><img src="/img/bento-tee.jpg" alt="Bento cake and matching cupcakes" width="700" height="525"></div>
      <div class="txt">
        <span class="eyebrow">Custom & celebration</span>
        <h3>Bring us the <em>occasion</em> — we'll design the cake.</h3>
        <p>Birthdays, engagements, baby showers, kitchen teas. Send us your theme, colours, and a picture or two for inspiration, and we'll design a cake to match — flavours, size, and finish, all sorted before you pay.</p>
        <a href={waBase} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
          <Icon name="whatsapp" class="wa-ico" /> Start a custom order
        </a>
      </div>
    </div>
  </div>
</section>

<!-- HOW -->
<section class="how">
  <div class="wrap">
    <div class="sec-head">
      <div class="lt">
        <span class="eyebrow">How it works</span>
        <h2>From idea to <em>cake</em> in four steps.</h2>
      </div>
    </div>
    <div class="steps">
      <div class="step"><div class="n">01</div><h4>Tell us the plan</h4><p>WhatsApp or call with the flavour, the date, your guest count, and the occasion. A reference picture helps.</p></div>
      <div class="step"><div class="n">02</div><h4>We'll quote & design</h4><p>We confirm a design, size, and price, and agree on collection or local delivery. A deposit secures the date.</p></div>
      <div class="step"><div class="n">03</div><h4>We bake fresh</h4><p>Your cake is layered and decorated the day before — never off a shelf — so it's at its best for your moment.</p></div>
      <div class="step"><div class="n">04</div><h4>Collect or delivered</h4><p>Pick it up from our kitchen or have it delivered and set up, boxed and ready to celebrate.</p></div>
    </div>
  </div>
</section>

<!-- LOVE -->
<section class="love">
  <div class="wrap">
    <div class="sec-head">
      <div class="lt">
        <span class="eyebrow">Love notes</span>
        <h2>Kind words from <em>kind people.</em></h2>
      </div>
    </div>
    <div class="love-grid">
      {testimonials.map((q) => (
        <div class="quote">
          <p class="t">{q.t}</p>
          <div class="by"><div class="av">{q.av}</div><div><div class="nm">{q.name}</div><div class="lo">{q.loc}</div></div></div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-band">
  <div class="wrap">
    <span class="eyebrow">Ready when you are</span>
    <h2>Let's bake <em>your cake.</em></h2>
    <p>Tell us the date and the occasion — we'll take care of the rest. Most cakes need {site.leadTime} notice.</p>
    <div class="ctas">
      <a class="btn btn-light btn-lg" href={orderWa} target="_blank" rel="noopener">
        <Icon name="whatsapp" class="wa-ico" /> Order on WhatsApp
      </a>
      <a class="btn btn-ghost btn-lg" href="/contact" style="color:var(--cream);border-color:rgba(250,243,232,.5)">Use the order form</a>
    </div>
  </div>
</section>

</Layout>
